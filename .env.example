# ── AI Provider Selection ──────────────────────────────────────────────────────
# First one set to "true" wins. Priority order: OpenAI → Gemini → Groq.
# If none is set to "true", OpenAI is used as the default.
USE_OPENAI=true
USE_GEMINI=false
USE_GROQ=false

# Model overrides (optional — these are the defaults if not set)
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile

# Provider API keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Speech Provider ────────────────────────────────────────────────────────────
# Controls Speech-to-Text (STT) only. TTS always uses OpenAI regardless.
#   "openai" → whisper-1 via OpenAI
#   "groq"   → whisper-large-v3 via Groq (free tier, faster)
SPEECH_PROVIDER=openai

# ── Map ────────────────────────────────────────────────────────────────────────
# MapTiler API Key (free tier — https://maptiler.com, no credit card required)
# Enables dark globe projection via MapLibre GL. Without this key, the map
# falls back to Leaflet + OpenStreetMap + CARTO dark tiles (zero config needed).
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_key_here

# ── Localization ───────────────────────────────────────────────────────────────
# Lingo.dev API Key — post-processes AI output into target UI language
LINGO_DEV_API_KEY=your_lingo_dev_api_key_here

# ── Optional ───────────────────────────────────────────────────────────────────
# ElevenLabs API Key (reserved for future enhanced TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
